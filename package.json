{
  "name": "starlight",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "yarn eslint .",
    "fix": "yarn eslint . --fix",
    "fmt": "yarn prettier -w .",
    "api:dev": "yarn workspace @starlight/api run dev",
    "ui:dev": "yarn workspace @starlight/ui run dev",
    "api:build": "yarn workspace @starlight/api run build",
    "ui:build": "yarn workspace @starlight/ui run build",
    "build": "tsc --build --verbose"
  },
  "packageManager": "yarn@4.7.0",
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^20.14.2",
    "eslint": "^9.22.0",
    "globals": "^15.3.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
